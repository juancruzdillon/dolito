# URL del JSON remoto con las comisiones de brokers.
# Creá un GitHub Gist con el archivo brokers.json (ver public/brokers.example.json)
# y pegá la URL raw acá.
#
# Ejemplo:
# VITE_BROKERS_CONFIG_URL=https://gist.githubusercontent.com/tu_usuario/abc123/raw/brokers.json
#
# Si no configurás esta variable, la app usa los valores hardcodeados de fallback.
VITE_BROKERS_CONFIG_URL=
